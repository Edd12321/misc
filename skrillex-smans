#include <math.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdlib.h>
#include <stdio.h>
#include <time.h>
#define RIFF_DUR 6.9f

static inline float saw(float ph) {
	return 2.f * (ph - floor(ph)) - 1.f;
}

/*
static inline float squ(float ph) {
	return ph - floor(ph) < .5f ? 1.f : -1.f;
