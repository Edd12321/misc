static inline float note(const char *s) {
	int t = 0;
	if (*s == 'X')
		return 0;
	switch (*s++) {
	case 'C': t =  0; break;
	case 'D': t =  2; break;
	case 'E': t =  4; break;
	case 'F': t =  5; break;
	case 'G': t =  7; break;
	case 'A': t =  9; break;
	case 'B': t = 11; break;
	}
	if (*s == '#') ++t, ++s;
	if (*s == 'b') --t, ++s;
	
	int n = (atoi(s) + 1) * 12 + t;
	return 440.f * powf(2, (n - 69.f) / 12.f);
}

// this was actually 2 different files but the beat works kinda ok with the lead
// so thats why here i take sample index and above i take phase as argument
int16_t drum(unsigned long long i) {
	static bool kick = true;
	static bool doublekick = false;
	int16_t sample = 0;

	float kludge = 44100.f * RIFF_DUR / 8.f;
	unsigned long long mod = i % (unsigned long long)kludge;
	if (i >= kludge && mod == 0) {
		kick = !kick;
		if (kick)
			doublekick = !doublekick;
	}
	
	if (kick) {
		if (mod <= 700 || (mod <= 900 && doublekick))
			sample = rand() % 3201 - 1600;
		else {
			float t = (float)mod / kludge;
			sample = exp(6 * -t) * 20000 * sin(M_PI * 2 * 600 * exp(-16*t) * t)
			       + exp(9 * -t) * (rand() % 301 - 150);
			if (doublekick && mod >= kludge/2) {
				t = (float)(mod - kludge/2) / kludge;
				sample += exp(6 * -t) * 22000 * sin(M_PI * 2 * 300 * exp(-14*t) * t)
				        + exp(9 * -t) * (rand() % 151 - 75);
			}
		}
	

	} else {
		float t = (float)mod / kludge;
		sample = exp(20 * -t) * 200 * (rand() % 1001 - 500);

		/*
		if (doublekick)
			sample += 2000.*sin(M_PI*50*sin(M_PI*6.4*t));
		*/
	}
	return sample;
}

float lead(float t) {
	static float ph = 0;
	static const char *song[] = {
		"G4", "G5", "F5", "G5", "A#5",
		"A#5", "G5", "D6", "C6", "A#5",
		"F4", "F4", "A#4", "A4", "F5",
		"D#5", "D5", "C5", "A#4", "F5",
		"A#4", "G4", "A#4", "D5", "G6",
		"D6", "A#5", "G5", "F6", "A#5",
		"G5", "F5"
	};
	static size_t len = sizeof song / sizeof *song;
	static float dur_note = RIFF_DUR / (sizeof song / sizeof *song);
	static float glis = .095f;

	size_t note_idx = fmod(t, RIFF_DUR) / RIFF_DUR * len;
	float freq = note(song[note_idx]);
	
	float glismod = fmod(t, dur_note) / dur_note;
	if (glismod >= 1.f - glis) {
		float nextfreq = note(song[note_idx + 1 >= len ? 0 : note_idx + 1]);
		freq += (nextfreq - freq) * (glismod - (1.f - glis)) / glis;
	}

	float mod = .4f * (sinf(2.f * M_PI * 80 * t) - 1.f);
	freq *= exp2f(mod / 12.f);

	ph += freq / 44100.f;
	if (ph >= 1.f) ph -= 1.f;
	return 5000.f * saw(ph);
}

int main() {
	unsigned long long i = 0;
	float t = 0;
	int16_t sample;

	srand(time(NULL));
	for (;; ++i, t = i * 1.f / 44100.f) {
		sample = lead(t);
		if (t >= RIFF_DUR)
			sample += drum(i);

		if (sample > 32767) sample = 32767;
		if (sample < -32768) sample = -32768; 
		if (t < 20.f)
			sample *= (t + 1) / 20.f;
		
		fwrite(&sample, sizeof sample, 1, stdout);
	}
}

